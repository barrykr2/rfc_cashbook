{
    "name": "RFC Cashbook",
    "image": "mcr.microsoft.com/devcontainers/php:1-8.2-bullseye",
    "customizations": {
        "vscode": {
            "extensions": [
                "bmewburn.vscode-intelephense-client",
                "xdebug.php-debug",
                "Google.geminicodeassist",
                "codeium.codeium",
                "alexcvzz.vscode-sqlite"
            ]
        }
    },
    "postCreateCommand": "composer install && sudo apt-get update && sudo apt-get install -y sqlite3 libsqlite3-dev"
}